# Configurações do Banco de Dados
DATABASE_URL=postgres://usuario:senha@host:porta/banco

# Autenticação JWT
JWT_SECRET=seu_segredo_super_seguro_aqui

# API Keys para serviços externos
OPS_CONSUMER_KEY=sua_chave_ops_aqui
OPS_CONSUMER_SECRET=seu_segredo_ops_aqui

# Configurações do INPI
INPI_MODE=scrape
INPI_USER=seu_usuario_inpi
INPI_PASSWORD=sua_senha_inpi

# APIs de IA
OLLAMA_BASE_URL=https://sua-url-ollama/
GEMINI_API_KEY=sua_chave_gemini_aqui
GROQ_API_KEY=sua_chave_groq_aqui

# Armazenamento S3
S3_ENDPOINT=https://seu-endpoint-s3/
S3_REGION=sua-regiao
S3_BUCKET=seu-bucket
S3_ACCESS_KEY=sua-access-key
S3_SECRET_KEY=sua-secret-key

# BigQuery
BIGQUERY_PROJECT_ID=seu-project-id
BIGQUERY_BILLING_PROJECT=seu-billing-project
GOOGLE_SERVICE_ACCOUNT_JSON=seu-json-de-service-account
BIGQUERY_MAX_BYTES_BILLED=50000000
BIGQUERY_CACHE_TTL_HOURS=720

# Anti-Captcha (OBRIGATÓRIO para scraping do INPI)
ANTI_CAPTCHA_API_KEY=sua_chave_api_anti_captcha_aqui

# Configurações do Puppeteer
PUPPETEER_EXECUTABLE_PATH=/caminho/para/chrome

# Processamento RPI
RPI_PROCESS_ORDER=desc