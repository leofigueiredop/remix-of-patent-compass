generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Authenticated Users (Admins/Consultants)
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  name          String?
  role          String   @default("user") // 'admin', 'user'
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

// 2. Clients (Companies/Individuals being monitored)
model Client {
  id         String   @id @default(uuid())
  name       String
  email      String?
  document   String?  // CNPJ/CPF
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  patents    Patent[]
}

// 3. Monitored Patents/Applications
model Patent {
  id             String           @id @default(uuid())
  client_id      String
  client         Client           @relation(fields: [client_id], references: [id])
  patent_number  String           // INPI Number (e.g., BR 10 2023...)
  title          String
  holder         String?          // Titular
  inventor       String?
  classification String?          // IPC/CPC
  status         String           @default("active") // 'active', 'inactive'
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  rules          MonitoringRule[]
  alerts         CollisionAlert[]
}

// 4. Monitoring Rules (The "Intellegence")
model MonitoringRule {
  id        String   @id @default(uuid())
  patent_id String
  patent    Patent   @relation(fields: [patent_id], references: [id])
  type      String   // 'exact_number', 'holder_wildcard', 'inventor_wildcard', 'keyword'
  value     String   // The search term (e.g., "Leonardo*Pickler")
}

// 5. Collision Alerts (Results from RPI Processing)
model CollisionAlert {
  id          String   @id @default(uuid())
  patent_id   String
  patent      Patent   @relation(fields: [patent_id], references: [id])
  rpi_number  String   // e.g., "2774"
  rpi_date    DateTime
  matched_text String  // What text in RPI triggered the alert?
  description String?  // AI Brief analysis of collision
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())
}

model SearchResultCache {
  id                 String   @id @default(uuid())
  source             String
  publication_number String
  title              String?
  applicant          String?
  inventor           String?
  patent_date        String?
  abstract           String?
  classification     String?
  url                String?
  status             String?
  figures            Json?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@unique([source, publication_number])
  @@index([publication_number])
}

// 6. INPI Scraper Worker Data
model InpiPatent {
  cod_pedido        String   @id
  numero_publicacao String?
  title             String?
  abstract          String?
  applicant         String?
  inventors         String?
  status            String?
  filing_date       String?
  ipc_codes         String?
  last_rpi          String?
  last_event        String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  publications      InpiPublication[]
  petitions          InpiPetition[]
  annuities         InpiAnnuity[]
  scraping_jobs     ScrapingJob[]
  document_jobs     DocumentDownloadJob[]

  @@map("inpi_patents")
}

model InpiPublication {
  id                String   @id @default(uuid())
  patent_id         String?
  patent            InpiPatent? @relation(fields: [patent_id], references: [cod_pedido], onDelete: SetNull)
  patent_number     String?
  rpi               String
  date              String?
  despacho_code     String?
  despacho_desc     String?
  complement        String?
  eligible_for_doc_download Boolean @default(false)
  bibliographic_status String? @default("pending")
  ops_docdb_id      String?
  ops_title         String?
  ops_applicant     String?
  ops_inventor      String?
  ops_ipc           String?
  ops_publication_date String?
  ops_error         String?
  ops_last_sync_at  DateTime?
  rpi_url           String?  // PDF of the RPI page
  has_image         Boolean  @default(false)
  created_at        DateTime @default(now())

  @@index([patent_id])
  @@index([patent_number])
  @@index([rpi])
}

model InpiPetition {
  id                String   @id @default(uuid())
  patent_id         String
  patent            InpiPatent @relation(fields: [patent_id], references: [cod_pedido])
  service_code      String?
  protocol          String?
  date              String?
  client            String?
  delivery          String?
  created_at        DateTime @default(now())

  @@index([patent_id])
}

model InpiAnnuity {
  id                String   @id @default(uuid())
  patent_id         String
  patent            InpiPatent @relation(fields: [patent_id], references: [cod_pedido])
  title             String?   // e.g. "3ª Anuidade"
  start_date        String?
  end_date          String?
  payment_date      String?
  status            String?   // 'paid', 'pending', etc.
  created_at        DateTime @default(now())

  @@index([patent_id])
}

model ScrapingJob {
  id                String   @id @default(uuid())
  patent_id         String
  patent            InpiPatent @relation(fields: [patent_id], references: [cod_pedido])
  status            String   @default("pending") // 'pending', 'running', 'completed', 'failed'
  error             String?
  attempts          Int      @default(0)
  last_attempt      DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([patent_id, status])
}

model RpiImportJob {
  id            String   @id @default(uuid())
  rpi_number    Int      @unique
  status        String   @default("pending")
  attempts      Int      @default(0)
  imported_count Int     @default(0)
  source_url    String?
  xml_file_name String?
  error         String?
  started_at    DateTime?
  finished_at   DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([status, created_at])
  @@index([rpi_number, status])
}

model DocumentDownloadJob {
  id                 String    @id @default(uuid())
  patent_id          String
  patent             InpiPatent @relation(fields: [patent_id], references: [cod_pedido])
  rpi_number         Int?
  publication_number String?
  status             String    @default("pending")
  attempts           Int       @default(0)
  storage_key        String?
  error              String?
  started_at         DateTime?
  finished_at        DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@unique([patent_id])
  @@index([status, created_at])
  @@index([rpi_number])
}

model OpsBibliographicJob {
  id                 String   @id @default(uuid())
  patent_number      String
  rpi_number         Int?
  status             String   @default("pending")
  attempts           Int      @default(0)
  docdb_id           String?
  error              String?
  started_at         DateTime?
  finished_at        DateTime?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@unique([patent_number])
  @@index([status, created_at])
}
